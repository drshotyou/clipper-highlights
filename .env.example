# Copy this file to .env before running docker compose.
#
# Docker Compose reads .env automatically. This works on Linux, macOS, and
# Windows without needing shell-specific environment variable syntax.
#
# If your recordings are inside the repo, you can leave this as ./data.
# On Windows, prefer forward slashes for absolute paths, for example:
# CLIPPER_MEDIA_DIR=C:/Users/you/Videos/clipper-input
CLIPPER_MEDIA_DIR=./data

# Optional. Leave blank if you want heuristic-only ranking.
GEMINI_API_KEY=
